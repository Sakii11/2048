<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="300dp"
    android:background="@drawable/bg_dialog"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="选择变幻目标值"
        android:textColor="@color/text_warm"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="285dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/magic_btn_2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_preview_tile_yellow"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/magic_btn_4"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_preview_tile_orange"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/magic_btn_8"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_preview_tile_light_orange"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="8"
            android:textColor="@color/text_warm"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/magic_btn_16"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_tile_16"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="16"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/magic_btn_32"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_tile_32"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="32"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 取消按钮 -->
    <Button
        android:id="@+id/magic_btn_cancel"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_btn_hammer"
        android:backgroundTint="@null"
        android:minWidth="80dp"
        android:text="取消"
        android:textColor="@color/text_white"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
